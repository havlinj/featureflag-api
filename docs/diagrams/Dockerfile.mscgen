# Minimal image for rendering Message Sequence Charts (mscgen).
# Build: docker build -f Dockerfile.mscgen -t featureflag-mscgen .
FROM ubuntu:22.04
ENV DEBIAN_FRONTEND=noninteractive
RUN apt-get update \
  && apt-get install -y --no-install-recommends mscgen \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /work
ENTRYPOINT ["mscgen"]
